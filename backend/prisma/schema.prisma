generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Note {
  id          Int       @id @default(autoincrement())
  title       String    @default("")
  content     String
  color       String
  Pinned      Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ShelfItem {
  id        Int      @id @default(autoincrement())
  type      String
  url       String?
  fileData  String?
  fileName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CalendarEvent {
  id          String   @id @default(uuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  allDay      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Resource {
  id          Int      @id @default(autoincrement())
  className   String
  description String   @default("")
  instructor  String   @default("")
  schedule    String   @default("")
  semester    String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StudySession {
  id              Int      @id @default(autoincrement())
  subject         String
  durationSeconds Int
  isBreak         Boolean  @default(false)
  mode            String
  completedAt     DateTime @default(now())
}

model StudySettings {
  id        Int @id @default(1)
  dailyGoal Int @default(5)
}
